---
import BaseLayout from '../layouts/BaseLayout.astro';
import { faqs } from '../data/site';
---

<BaseLayout title="FAQ" description="Answers to common questions about Americall appointment-setting, calling services, CRM support, and website content editing.">
	<section class="soft-grid bg-ameri-soft px-5 py-20 lg:px-8">
		<div class="reveal mx-auto max-w-4xl">
			<p class="text-sm font-black uppercase tracking-wide text-ameri-red">FAQ</p>
			<h1 class="mt-3 text-4xl font-black text-ameri-navy sm:text-5xl">Questions before booking a demo?</h1>
			<p class="mt-5 text-lg leading-8 text-ameri-muted">
				Here are the basics prospects usually need before talking with Americall.
			</p>
		</div>
	</section>
	<section class="px-5 py-16 lg:px-8">
		<div class="reveal mx-auto max-w-4xl divide-y divide-ameri-border rounded-2xl border border-ameri-border bg-white shadow-sm">
			{faqs.map((faq) => (
				<details class="group p-6 transition hover:bg-ameri-soft/70 first:rounded-t-2xl last:rounded-b-2xl">
					<summary class="flex cursor-pointer list-none items-start justify-between gap-5 text-lg font-black text-ameri-navy transition group-open:text-ameri-red">
						<span>{faq.question}</span>
						<span class="faq-chevron mt-1 grid h-5 w-5 shrink-0 place-items-center text-ameri-navy" aria-hidden="true">
							<svg viewBox="0 0 20 20" class="h-4 w-4" fill="none">
								<path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</span>
					</summary>
					<div class="faq-answer">
						<div>
							<p class="mt-4 leading-8 text-ameri-muted">{faq.answer}</p>
						</div>
					</div>
				</details>
			))}
		</div>
	</section>
	<section class="px-5 pb-20 lg:px-8">
		<div class="reveal mx-auto grid max-w-4xl items-center gap-6 rounded-2xl border border-ameri-border bg-ameri-soft p-6 shadow-card sm:p-8 md:grid-cols-[1fr_auto]">
			<div>
				<p class="text-sm font-black uppercase tracking-wide text-ameri-red">Book a demo</p>
				<h2 class="mt-2 text-2xl font-black text-ameri-navy">Still want to talk through your campaign?</h2>
				<p class="mt-3 leading-7 text-ameri-muted">
					Share your appointment goals, current tools, and target market. Americall can walk you through the right service mix and package fit on a short demo call.
				</p>
			</div>
			<a class="button-motion rounded-xl bg-ameri-red px-6 py-3 text-center text-sm font-black text-white shadow-lg shadow-ameri-red/20 hover:bg-red-700" href="/contact/">
				<span>Book a Free Demo</span>
			</a>
		</div>
	</section>
</BaseLayout>
