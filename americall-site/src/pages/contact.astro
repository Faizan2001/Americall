---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Book a free demo with Americall to discuss appointment-setting, campaign support, and calling operations.">
	<section class="grid-surface bg-ameri-navy px-5 py-20 text-white lg:px-8">
		<div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
			<div class="reveal">
				<p class="text-sm font-black uppercase tracking-wide text-white/70">Book a demo</p>
				<h1 class="mt-3 text-4xl font-black leading-tight sm:text-5xl">Let's build a calling system that actually works.</h1>
				<p class="mt-5 text-lg leading-8 text-white/75">
					In a short demo call, Americall can walk you through how its calling, qualification, confirmation, and support process can fit your sales operation.
				</p>

			</div>
			<div class="relative w-full">
				<!-- Success Message (Shown by Formspree after submission) -->
				<div style="display: none;" class="rounded-2xl bg-green-50 p-8 text-center text-green-900 shadow-2xl shadow-black/25" data-fs-success>
					<div class="mx-auto grid h-16 w-16 place-items-center rounded-full bg-green-200">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-green-700"><path d="M20 6L9 17l-5-5"/></svg>
					</div>
					<h3 class="mt-4 text-2xl font-black">Request Sent!</h3>
					<p class="mt-3 text-base leading-6">We've received your information and will reach out to schedule your demo shortly.</p>
				</div>

				<form id="demo-form" class="reveal rounded-2xl bg-white p-6 text-ameri-ink shadow-2xl shadow-black/25 sm:p-8">
					<!-- General Error Message -->
					<div style="display: none;" class="mb-6 rounded-xl bg-red-50 p-4 text-sm font-bold text-red-700" data-fs-error>
						There was a problem submitting your request. Please check your inputs and try again.
					</div>
					
					<!-- Spam Honeypot -->
					<input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
					
					<div class="grid gap-5 sm:grid-cols-2">
						<label class="block">
							<span class="text-sm font-bold text-ameri-navy">First name*</span>
							<input class="mt-2 w-full rounded-xl border border-ameri-border px-4 py-3 transition focus:border-ameri-red focus:ring-2 focus:ring-ameri-red/15 data-[invalid]:border-red-500" name="firstName" autocomplete="given-name" required data-fs-field />
							<span class="mt-1 hidden text-xs text-red-500" data-fs-error="firstName"></span>
						</label>
						<label class="block">
							<span class="text-sm font-bold text-ameri-navy">Last name*</span>
							<input class="mt-2 w-full rounded-xl border border-ameri-border px-4 py-3 transition focus:border-ameri-red focus:ring-2 focus:ring-ameri-red/15 data-[invalid]:border-red-500" name="lastName" autocomplete="family-name" required data-fs-field />
							<span class="mt-1 hidden text-xs text-red-500" data-fs-error="lastName"></span>
						</label>
						<label class="block sm:col-span-2">
							<span class="text-sm font-bold text-ameri-navy">Designation</span>
							<input class="mt-2 w-full rounded-xl border border-ameri-border px-4 py-3 transition focus:border-ameri-red focus:ring-2 focus:ring-ameri-red/15 data-[invalid]:border-red-500" name="designation" autocomplete="organization-title" data-fs-field />
							<span class="mt-1 hidden text-xs text-red-500" data-fs-error="designation"></span>
						</label>
						<label class="block sm:col-span-2">
							<span class="text-sm font-bold text-ameri-navy">Company*</span>
							<input class="mt-2 w-full rounded-xl border border-ameri-border px-4 py-3 transition focus:border-ameri-red focus:ring-2 focus:ring-ameri-red/15 data-[invalid]:border-red-500" name="company" autocomplete="organization" required data-fs-field />
							<span class="mt-1 hidden text-xs text-red-500" data-fs-error="company"></span>
						</label>
						<label class="block sm:col-span-2">
							<span class="text-sm font-bold text-ameri-navy">Business email*</span>
							<input class="mt-2 w-full rounded-xl border border-ameri-border px-4 py-3 transition focus:border-ameri-red focus:ring-2 focus:ring-ameri-red/15 data-[invalid]:border-red-500" type="email" name="email" autocomplete="email" required data-fs-field />
							<span class="mt-1 hidden text-xs text-red-500" data-fs-error="email"></span>
						</label>
						<label class="block sm:col-span-2">
							<span class="text-sm font-bold text-ameri-navy">Contact number*</span>
							<input class="mt-2 w-full rounded-xl border border-ameri-border px-4 py-3 transition focus:border-ameri-red focus:ring-2 focus:ring-ameri-red/15 data-[invalid]:border-red-500" type="tel" name="phone" autocomplete="tel" required data-fs-field />
							<span class="mt-1 hidden text-xs text-red-500" data-fs-error="phone"></span>
						</label>
						<label class="block sm:col-span-2">
							<span class="text-sm font-bold text-ameri-navy">Monthly appointment volume</span>
							<select class="mt-2 w-full rounded-xl border border-ameri-border bg-white px-4 py-3 transition focus:border-ameri-red focus:ring-2 focus:ring-ameri-red/15 data-[invalid]:border-red-500" name="monthlyAppointmentVolume" data-fs-field>
								<option value="">Select appointment volume</option>
								<option value="Under 100 appointments/mo">Under 100 appointments/mo</option>
								<option value="100-500 appointments/mo">100-500 appointments/mo</option>
								<option value="500-1,000 appointments/mo">500-1,000 appointments/mo</option>
								<option value="1,000+/mo">1,000+/mo</option>
								<option value="Not sure yet">Not sure yet</option>
							</select>
							<span class="mt-1 hidden text-xs text-red-500" data-fs-error="monthlyAppointmentVolume"></span>
						</label>
						<label class="block sm:col-span-2">
							<span class="text-sm font-bold text-ameri-navy">How can Americall, Inc. help with campaign management?</span>
							<textarea class="mt-2 min-h-32 w-full rounded-xl border border-ameri-border px-4 py-3 transition focus:border-ameri-red focus:ring-2 focus:ring-ameri-red/15 data-[invalid]:border-red-500" name="message" data-fs-field></textarea>
							<span class="mt-1 hidden text-xs text-red-500" data-fs-error="message"></span>
						</label>
					</div>
					<button class="button-motion mt-6 w-full rounded-xl bg-ameri-red px-6 py-3 text-sm font-black text-white hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed" type="submit" data-fs-submit-btn>
						<span>Book a Free Demo</span>
					</button>
				</form>
			</div>
		</div>
	</section>

	<script>
		const form = document.getElementById('demo-form') as HTMLFormElement | null;
		const successMsg = document.querySelector('[data-fs-success]') as HTMLElement | null;
		const errorMsg = document.querySelector('[data-fs-error]') as HTMLElement | null;
		const submitBtn = document.querySelector('[data-fs-submit-btn]') as HTMLButtonElement | null;

		if (form && successMsg && errorMsg && submitBtn) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				
				// Prevent double-clicks and show loading state
				submitBtn.disabled = true;
				submitBtn.innerHTML = '<span>Sending...</span>';
				errorMsg.style.display = 'none';

				try {
					const formData = new FormData(form);
					const response = await fetch('https://formspree.io/f/xbdqyony', {
						method: 'POST',
						body: formData,
						headers: {
							'Accept': 'application/json'
						}
					});

					if (response.ok) {
						// Hide form and show success message
						form.style.display = 'none';
						successMsg.style.display = 'block';
					} else {
						throw new Error('Form submission failed');
					}
				} catch (err) {
					// Show error and reset button
					errorMsg.style.display = 'block';
					submitBtn.disabled = false;
					submitBtn.innerHTML = '<span>Book a Free Demo</span>';
				}
			});
		}
	</script>
</BaseLayout>
