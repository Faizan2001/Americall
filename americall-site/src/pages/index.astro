---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services, stats, testimonials } from '../data/site';
---

<BaseLayout
	title="Trained Calling Teams For Qualified Appointments"
	description="Americall helps U.S. service businesses turn call operations into qualified appointments with trained agents, campaign management, and reliable support."
>
	<!-- ═══ HERO ═══ -->
	<section class="grid-surface relative overflow-hidden bg-ameri-navy text-white">
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_20%,rgba(215,25,32,0.08)_0%,transparent_60%)]"></div>
		<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
		<div class="relative mx-auto grid max-w-7xl items-center gap-10 px-5 py-14 sm:py-16 lg:min-h-[calc(100vh-73px)] lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-20">
			<div class="reveal">
				<p class="inline-flex rounded-xl border border-white/15 bg-white/10 px-3 py-1 text-sm font-bold text-white/85 shadow-sm backdrop-blur">
					30,000+ qualified appointments sent
				</p>
				<h1 class="mt-6 max-w-4xl text-3xl font-black leading-tight sm:text-5xl lg:text-6xl">
					Trained calling teams that turn interest into booked appointments.
				</h1>
				<p class="mt-5 max-w-2xl text-base leading-7 text-white/78 sm:mt-6 sm:text-lg sm:leading-8">
					Americall supports solar, roofing, HVAC, real estate, and home improvement businesses with trained agents, campaign management, CRM support, and appointment-setting operations built around your goals.
				</p>
				<div class="mt-9 flex flex-col gap-3 sm:flex-row">
					<a class="button-motion rounded-xl bg-ameri-red px-6 py-3 text-center text-sm font-black text-white shadow-lg shadow-black/20 hover:bg-red-700" href="/contact/">
						<span>Book a Free Demo</span>
					</a>
					<a class="button-motion rounded-xl border border-white/25 px-6 py-3 text-center text-sm font-black text-white hover:bg-white hover:text-ameri-navy" href="/services/">
						<span>View Services</span>
					</a>
				</div>
			</div>
			<div class="reveal relative">
				<div class="relative group perspective-1000">
					<div class="absolute -inset-1 rounded-2xl bg-gradient-to-tr from-ameri-red to-blue-500 opacity-20 blur-xl transition duration-500 group-hover:opacity-40"></div>
					<img
						src="/images/modern-abstract-hero.png"
						alt="Modern call center dashboard and headset"
						class="relative mx-auto h-auto w-full max-w-md rounded-2xl object-cover shadow-2xl transition duration-500 group-hover:-translate-y-2 group-hover:shadow-[0_32px_64px_rgba(2,18,44,0.3)]"
						width="1024"
						height="1024"
						loading="eager"
					/>
				</div>
				<div class="mt-6 grid grid-cols-3 gap-2 sm:gap-3">
					<div class="lift-card rounded-2xl border border-white/12 bg-white/10 p-3 text-white backdrop-blur sm:p-4">
						<p class="text-xl font-black sm:text-2xl">500+</p>
						<p class="mt-1 text-[0.65rem] font-bold uppercase leading-tight tracking-wide text-white/65 sm:text-xs">Trained agents</p>
					</div>
					<div class="lift-card rounded-2xl border border-white/12 bg-white/10 p-3 text-white backdrop-blur sm:p-4">
						<p class="text-xl font-black sm:text-2xl">12K+</p>
						<p class="mt-1 text-[0.65rem] font-bold uppercase leading-tight tracking-wide text-white/65 sm:text-xs">Confirmed sits</p>
					</div>
					<div class="lift-card rounded-2xl border border-white/12 bg-white/10 p-3 text-white backdrop-blur sm:p-4">
						<p class="text-xl font-black sm:text-2xl">3K+</p>
						<p class="mt-1 text-[0.65rem] font-bold uppercase leading-tight tracking-wide text-white/65 sm:text-xs">Sold deals</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ SERVICES CAROUSEL ═══ -->
	<section class="overflow-hidden bg-white px-5 py-16 sm:py-20 lg:px-8" id="services">
		<div class="mx-auto max-w-7xl">
			<div class="reveal flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
				<div class="max-w-3xl">
					<p class="text-sm font-black uppercase tracking-wide text-ameri-red">Services</p>
					<h2 class="mt-3 text-3xl font-black text-ameri-navy sm:text-4xl">Calling operations built around your sales pipeline.</h2>
					<p class="mt-4 text-base leading-7 text-ameri-muted sm:text-lg sm:leading-8">
						From dialing systems to trained agents and confirmation support, Americall helps your team protect time and focus on closing.
					</p>
				</div>
				<div class="flex items-center gap-3">
					<button class="carousel-arrow" id="carousel-prev" aria-label="Previous service" type="button">
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
					</button>
					<button class="carousel-arrow" id="carousel-next" aria-label="Next service" type="button">
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
					</button>
					<a class="button-motion inline-flex w-fit rounded-xl border border-ameri-border px-5 py-3 text-sm font-black text-ameri-navy hover:border-ameri-red hover:text-ameri-red" href="/services/">
						<span>Explore Services</span>
					</a>
				</div>
			</div>
			<div class="carousel-mask reveal mt-12">
				<div class="draggable-carousel py-3" id="services-carousel">
					{[...services, ...services, ...services].map((service, index) => {
						const realIndex = index % services.length;
						return (
							<article class="lift-card group flex min-h-64 w-[82vw] shrink-0 flex-col rounded-2xl border border-ameri-border bg-white p-5 hover:border-ameri-red/35 sm:min-h-72 sm:w-[22rem] sm:p-6" data-index={realIndex}>
								<div class="flex items-center justify-between">
									<div class="grid h-11 w-11 place-items-center rounded-xl bg-ameri-navy text-sm font-black text-white transition group-hover:bg-ameri-red">
										{String(realIndex + 1).padStart(2, '0')}
									</div>
									<span class="rounded-xl bg-ameri-soft px-3 py-1 text-xs font-black uppercase tracking-wide text-ameri-muted">BPO support</span>
								</div>
								<h3 class="mt-7 text-xl font-black text-ameri-navy">{service.title}</h3>
								<p class="mt-3 leading-7 text-ameri-muted">{service.description}</p>
								<div class="mt-auto pt-6 text-sm font-black text-ameri-red">Built for qualified conversations</div>
							</article>
						);
					})}
				</div>
			</div>
			<div class="mt-6 flex justify-center gap-2" id="carousel-dots">
				{services.map((_, index) => (
					<button class={`carousel-dot ${index === 0 ? 'is-active' : ''}`} aria-label={`Go to service ${index + 1}`} data-index={index} type="button"></button>
				))}
			</div>
		</div>
	</section>

	<!-- ═══ PROOF / STATS ═══ -->
	<section class="soft-grid bg-ameri-soft px-5 py-16 sm:py-20 lg:px-8">
		<div class="mx-auto max-w-7xl">
			<div class="reveal mx-auto max-w-3xl text-center">
				<p class="text-sm font-black uppercase tracking-wide text-ameri-red">Proof</p>
				<h2 class="mt-3 text-3xl font-black text-ameri-navy sm:text-4xl">Proof built through thousands of calls.</h2>
				<p class="mt-4 text-base leading-7 text-ameri-muted sm:text-lg sm:leading-8">
					Five years in, Americall has built the team, process, and operating discipline to support growth-focused U.S. businesses.
				</p>
			</div>
			<div class="mt-9 grid gap-3 sm:hidden">
				{stats.map((stat) => (
					<details class="rounded-2xl border border-white bg-white p-4 shadow-sm">
						<summary class="flex cursor-pointer list-none items-center justify-between gap-4">
							<div>
								<p class="text-2xl font-black text-ameri-red">{stat.value}</p>
								<h3 class="mt-1 text-sm font-black text-ameri-navy">{stat.label}</h3>
							</div>
							<span class="faq-chevron grid h-5 w-5 shrink-0 place-items-center text-ameri-navy" aria-hidden="true">
								<svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
									<path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
								</svg>
							</span>
						</summary>
						<div class="faq-answer">
							<div>
								<p class="pt-3 text-sm leading-6 text-ameri-muted">{stat.description}</p>
							</div>
						</div>
					</details>
				))}
			</div>
			<div class="mt-12 hidden gap-5 sm:grid md:grid-cols-2 lg:grid-cols-3">
				{stats.map((stat) => (
					<article class="reveal stats-tile">
						<p class="text-4xl font-black text-ameri-red">{stat.value}</p>
						<h3 class="mt-3 text-lg font-black text-ameri-navy">{stat.label}</h3>
						<p class="mt-3 leading-7 text-ameri-muted">{stat.description}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- ═══ TRUST + TESTIMONIALS ═══ -->
	<section class="relative overflow-hidden bg-white px-5 py-14 sm:py-20 lg:px-8">
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_80%_50%,rgba(245,247,250,0.9)_0%,transparent_70%)]"></div>
		<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-ameri-border to-transparent"></div>
		<div class="relative mx-auto grid max-w-7xl items-start gap-10 lg:grid-cols-[0.9fr_1.1fr]">
			<div class="reveal max-w-2xl">
				<p class="text-sm font-black uppercase tracking-wide text-ameri-red">Trust</p>
				<h2 class="mt-3 text-3xl font-black leading-tight text-ameri-navy sm:text-4xl">
					Less chasing. More sales-ready appointments.
				</h2>
				<p class="mt-5 text-base leading-7 text-ameri-muted sm:text-lg sm:leading-8">
					Americall handles the calling, qualification, confirmation, and handoff work before your sales team arrives, so every appointment starts with better context.
				</p>
				<div class="mt-7 grid grid-cols-3 gap-2 sm:gap-3">
					<div class="rounded-2xl border border-ameri-border bg-white p-3 shadow-sm sm:p-4">
						<p class="text-xl font-black text-ameri-red sm:text-2xl">30K+</p>
						<p class="mt-1 text-[0.63rem] font-black uppercase leading-tight tracking-wide text-ameri-muted sm:text-xs">Appointments sent</p>
					</div>
					<div class="rounded-2xl border border-ameri-border bg-white p-3 shadow-sm sm:p-4">
						<p class="text-xl font-black text-ameri-red sm:text-2xl">12K+</p>
						<p class="mt-1 text-[0.63rem] font-black uppercase leading-tight tracking-wide text-ameri-muted sm:text-xs">Confirmed sit-ins</p>
					</div>
					<div class="rounded-2xl border border-ameri-border bg-white p-3 shadow-sm sm:p-4">
						<p class="text-xl font-black text-ameri-red sm:text-2xl">5/5</p>
						<p class="mt-1 text-[0.63rem] font-black uppercase leading-tight tracking-wide text-ameri-muted sm:text-xs">Client feedback</p>
					</div>
				</div>
				<div class="mt-8 grid grid-cols-2 gap-3 sm:flex sm:flex-row">
					<a class="button-motion rounded-xl bg-ameri-red px-6 py-3 text-center text-sm font-black text-white shadow-lg shadow-ameri-red/20 hover:bg-red-700" href="/contact/">
						<span class="sm:hidden">Book Demo</span>
						<span class="hidden sm:inline">Start the Conversation</span>
					</a>
					<a class="button-motion rounded-xl border border-ameri-border bg-white px-6 py-3 text-center text-sm font-black text-ameri-navy hover:border-ameri-red hover:text-ameri-red" href="/services/">
						<span>See the Process</span>
					</a>
				</div>
			</div>

			<!-- Modernized Testimonial Cards -->
			<div class="testimonials-grid mt-8">
				{testimonials.map((testimonial, index) => (
					<figure class="reveal testimonial-card">
						<span class="quote-watermark" aria-hidden="true">&rdquo;</span>
						<div class="relative z-10 flex items-center justify-between gap-4">
							<div class="star-rating" aria-label="5 out of 5 rating">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
							</div>
							<span class="inline-flex items-center gap-1.5 rounded-xl bg-green-50 px-3 py-1 text-xs font-bold text-green-700">
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
								Verified client
							</span>
						</div>
						<blockquote class="relative z-10 mt-6 text-base font-semibold leading-7 text-ameri-navy sm:text-lg sm:leading-8">
							&ldquo;{testimonial.quote}&rdquo;
						</blockquote>
						<figcaption class="relative z-10 mt-7 flex items-center gap-4 border-t border-ameri-border/50 pt-5">
							<div class="avatar-ring">
								<span>{testimonial.name.split(' ').map((part) => part[0]).join('')}</span>
							</div>
							<div>
								<p class="font-black text-ameri-navy">{testimonial.name}</p>
								<p class="mt-0.5 text-sm leading-6 text-ameri-muted">{testimonial.role}</p>
							</div>
						</figcaption>
					</figure>
				))}
			</div>
		</div>
	</section>

	<!-- ═══ CTA BAND ═══ -->
	<section class="grid-surface bg-ameri-navy px-5 py-16 text-white sm:py-20 lg:px-8">
		<div class="reveal mx-auto grid max-w-7xl items-center gap-8 lg:grid-cols-[1fr_auto]">
			<div>
				<p class="text-sm font-black uppercase tracking-wide text-white/70">Book a demo</p>
				<h2 class="mt-3 text-3xl font-black sm:text-4xl">Let's build a calling system that actually works.</h2>
				<p class="mt-4 max-w-2xl text-base leading-7 text-white/75 sm:text-lg sm:leading-8">
					In a short demo call, Americall can walk you through how its calling, qualification, confirmation, and support process can fit your sales operation.
				</p>
			</div>
			<a class="button-motion rounded-xl bg-ameri-red px-7 py-4 text-center text-sm font-black text-white hover:bg-red-700" href="/contact/">
				<span>Book a Free Demo</span>
			</a>
		</div>
	</section>

	<!-- ═══ DRAGGABLE CAROUSEL SCRIPT ═══ -->
	<script>
		const carousel = document.getElementById('services-carousel') as HTMLElement | null;
		const prevBtn = document.getElementById('carousel-prev') as HTMLButtonElement | null;
		const nextBtn = document.getElementById('carousel-next') as HTMLButtonElement | null;
		const dotsContainer = document.getElementById('carousel-dots') as HTMLElement | null;
		const dots = dotsContainer ? Array.from(dotsContainer.querySelectorAll('.carousel-dot')) as HTMLElement[] : [];
		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (carousel) {
			const cards = Array.from(carousel.children) as HTMLElement[];
			let isDragging = false;
			let startX = 0;
			let scrollStart = 0;
			let autoScrollId: number | null = null;
			let idleTimeout: number | null = null;
			let direction = 1; // 1 for right, -1 for left

			const isMobile = () => window.innerWidth < 768;

			/* ── Get card width for scroll distance ── */
			function getScrollAmount(): number {
				const card = cards[0];
				if (!card) return 300;
				const style = getComputedStyle(carousel!);
				const gap = parseFloat(style.gap) || 20;
				return card.offsetWidth + gap;
			}

			/* ── Get single set width for infinite scrolling ── */
			function getSingleSetWidth(): number {
				return carousel!.scrollWidth / 3;
			}

			/* ── Update dot indicators ── */
			function updateDots(): void {
				if (!carousel || dots.length === 0) return;
				const scrollAmount = getScrollAmount();
				const setWidth = getSingleSetWidth();
				const normalizedScroll = carousel.scrollLeft % setWidth;
				const activeIndex = Math.round(normalizedScroll / scrollAmount);
				dots.forEach((dot, i) => {
					dot.classList.toggle('is-active', i === Math.min(activeIndex, dots.length - 1));
				});
			}

			/* ── Arrow navigation ── */
			prevBtn?.addEventListener('click', () => {
				carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
				pauseAutoScroll();
				scheduleResume();
			});

			nextBtn?.addEventListener('click', () => {
				carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
				pauseAutoScroll();
				scheduleResume();
			});

			/* ── Dot navigation ── */
			dots.forEach((dot) => {
				dot.addEventListener('click', () => {
					const index = parseInt(dot.dataset.index || '0', 10);
					const setWidth = getSingleSetWidth();
					carousel.scrollTo({ left: setWidth + (index * getScrollAmount()), behavior: 'smooth' });
					pauseAutoScroll();
					scheduleResume();
				});
			});

			/* ── Mouse drag ── */
			carousel.addEventListener('mousedown', (e: MouseEvent) => {
				isDragging = true;
				startX = e.pageX;
				scrollStart = carousel.scrollLeft;
				carousel.classList.add('is-dragging');
				pauseAutoScroll();
			});

			document.addEventListener('mousemove', (e: MouseEvent) => {
				if (!isDragging) return;
				e.preventDefault();
				const dx = e.pageX - startX;
				carousel.scrollLeft = scrollStart - dx;
			});

			document.addEventListener('mouseup', () => {
				if (!isDragging) return;
				isDragging = false;
				carousel.classList.remove('is-dragging');
				scheduleResume();
			});

			/* ── Touch handling (native scroll-snap works, just pause auto-scroll) ── */
			carousel.addEventListener('touchstart', () => {
				pauseAutoScroll();
			}, { passive: true });

			carousel.addEventListener('touchend', () => {
				scheduleResume();
			}, { passive: true });

			/* ── Scroll event for dot sync & infinite wrap ── */
			let scrollTick = false;
			carousel.addEventListener('scroll', () => {
				if (!scrollTick) {
					requestAnimationFrame(() => {
						const setWidth = getSingleSetWidth();
						
						// Infinite wrap logic (Desktop only)
						if (!isMobile()) {
							if (carousel!.scrollLeft >= setWidth * 2) {
								carousel!.scrollLeft -= setWidth;
							} else if (carousel!.scrollLeft <= 0) {
								carousel!.scrollLeft += setWidth;
							}
						}

						updateDots();
						scrollTick = false;
					});
					scrollTick = true;
				}
			}, { passive: true });

			/* ── Auto-scroll (Continuous) ── */
			function startAutoScroll(): void {
				if (reducedMotion) return;
				pauseAutoScroll();
				
				carousel!.classList.add('is-auto-scrolling');
				
				function step() {
					if (!isDragging) {
						if (isMobile()) {
							const setWidth = getSingleSetWidth();
							const minScroll = setWidth;
							// Buffer so we don't jump past max bounds
							const maxScroll = setWidth * 2 - carousel!.clientWidth;
							
							carousel!.scrollLeft += direction * 1;
							
							if (carousel!.scrollLeft >= maxScroll) {
								direction = -1;
							} else if (carousel!.scrollLeft <= minScroll) {
								direction = 1;
							}
						} else {
							carousel!.scrollLeft += 1; // Slow continuous speed
						}
					}
					autoScrollId = requestAnimationFrame(step);
				}
				autoScrollId = requestAnimationFrame(step);
			}

			function pauseAutoScroll(): void {
				if (autoScrollId !== null) {
					cancelAnimationFrame(autoScrollId);
					autoScrollId = null;
				}
				carousel?.classList.remove('is-auto-scrolling');
				if (idleTimeout !== null) {
					clearTimeout(idleTimeout);
					idleTimeout = null;
				}
			}

			function scheduleResume(): void {
				if (idleTimeout !== null) clearTimeout(idleTimeout);
				idleTimeout = window.setTimeout(() => {
					startAutoScroll();
				}, 5000); // Resume after 5 seconds of interaction
			}

			/* ── Init ── */
			const setWidth = getSingleSetWidth();
			carousel.scrollLeft = setWidth; // Start in the middle set
			updateDots();
			startAutoScroll();
		}
	</script>
</BaseLayout>
