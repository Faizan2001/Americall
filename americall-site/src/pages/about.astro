---
import BaseLayout from '../layouts/BaseLayout.astro';
import { agents } from '../data/site';
---

<BaseLayout title="About Us" description="Meet the Americall team and learn how trained agents support appointment-setting and calling campaigns.">
	<!-- ═══ ABOUT HERO ═══ -->
	<section class="grid-surface relative overflow-hidden bg-ameri-navy px-5 py-20 text-white lg:px-8">
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_70%_30%,rgba(215,25,32,0.06)_0%,transparent_60%)]"></div>
		<div class="relative mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[1fr_380px]">
			<div class="reveal">
				<p class="text-sm font-black uppercase tracking-wide text-white/70">About Americall</p>
				<h1 class="mt-3 max-w-4xl text-4xl font-black leading-tight sm:text-5xl">
					A calling partner built on training, consistency, and follow-through.
				</h1>
				<p class="mt-5 max-w-3xl text-lg leading-8 text-white/75">
					Americall supports businesses that need reliable appointment-setting operations, trained agents, confirmation workflows, and campaign support that connects daily calling activity to sales outcomes.
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<a class="button-motion rounded-2xl bg-ameri-red px-6 py-3 text-center text-sm font-black text-white shadow-lg shadow-ameri-red/25 hover:bg-red-700" href="/contact/">
						<span>Work With Us</span>
					</a>
					<a class="button-motion rounded-2xl border border-white/25 px-6 py-3 text-center text-sm font-black text-white hover:bg-white hover:text-ameri-navy" href="/services/">
						<span>Our Services</span>
					</a>
				</div>
			</div>
			<div class="reveal">
				<div class="about-hero-eagle mx-auto max-w-[320px]">
					<img
						src="/images/americall-hero-eagle.png"
						alt="Americall eagle headset mascot"
						class="h-auto w-full rounded-2xl object-contain"
						width="512"
						height="512"
						loading="eager"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ WHY AMERICALL ═══ -->
	<section class="bg-ameri-soft px-5 py-16 sm:py-20 lg:px-8">
		<div class="mx-auto max-w-7xl">
			<div class="reveal mx-auto max-w-3xl text-center">
				<p class="text-sm font-black uppercase tracking-wide text-ameri-red">Why Americall</p>
				<h2 class="mt-3 text-3xl font-black text-ameri-navy sm:text-4xl">What sets us apart</h2>
				<p class="mt-4 text-base leading-7 text-ameri-muted sm:text-lg sm:leading-8">
					We don't just make calls. We build calling operations that protect your team's time and deliver appointments your sales team can close.
				</p>
			</div>
			<div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
				<div class="reveal about-feature-card">
					<div class="about-feature-icon">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
					</div>
					<h3 class="text-lg font-black text-ameri-navy">Trained Teams</h3>
					<p class="text-sm leading-6 text-ameri-muted">500+ agents recruited, trained, and managed to represent your brand with consistency on every call.</p>
				</div>
				<div class="reveal about-feature-card">
					<div class="about-feature-icon">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
					</div>
					<h3 class="text-lg font-black text-ameri-navy">Quality First</h3>
					<p class="text-sm leading-6 text-ameri-muted">Every appointment goes through QA before reaching your team, so you sit with prospects who are genuinely interested.</p>
				</div>
				<div class="reveal about-feature-card">
					<div class="about-feature-icon">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
					</div>
					<h3 class="text-lg font-black text-ameri-navy">CRM & Dialer</h3>
					<p class="text-sm leading-6 text-ameri-muted">Integrated with Salesforce, HubSpot, GoHighLevel, and popular scheduling tools your team already uses.</p>
				</div>
				<div class="reveal about-feature-card">
					<div class="about-feature-icon">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
					</div>
					<h3 class="text-lg font-black text-ameri-navy">U.S. Focused</h3>
					<p class="text-sm leading-6 text-ameri-muted">Deep experience in solar, roofing, HVAC, real estate, and home improvement industries across all 50 states.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ AGENT VOICES ═══ -->
	<section class="px-5 py-20 lg:px-8">
		<div class="mx-auto max-w-7xl">
			<div class="reveal max-w-3xl">
				<p class="text-sm font-black uppercase tracking-wide text-ameri-red">Agent voices</p>
				<h2 class="mt-3 text-3xl font-black text-ameri-navy sm:text-4xl">The human side of every campaign.</h2>
				<p class="mt-4 text-lg leading-8 text-ameri-muted">
					These are placeholder profiles for now. Replace them with real agent photos, names, quotes, and short voice clips before launch.
				</p>
			</div>
			<div class="mt-12 grid gap-6 md:grid-cols-3">
				{agents.map((agent) => (
					<article class="reveal lift-card group rounded-2xl border border-ameri-border bg-white p-6 hover:border-ameri-red/35">
						<div class="grid aspect-square place-items-center rounded-2xl bg-ameri-soft text-4xl font-black text-ameri-navy transition group-hover:bg-ameri-navy group-hover:text-white">
							{agent.initials}
						</div>
						<h3 class="mt-6 text-xl font-black text-ameri-navy">{agent.name}</h3>
						<p class="mt-1 text-sm font-bold uppercase tracking-wide text-ameri-red">{agent.role}</p>
						<p class="mt-4 leading-7 text-ameri-muted">"{agent.quote}"</p>
						<button
							type="button"
							class="mt-6 w-full rounded-xl border border-ameri-border px-4 py-3 text-sm font-black text-ameri-navy transition hover:border-ameri-red hover:text-ameri-red disabled:cursor-not-allowed disabled:opacity-60"
							data-audio={agent.audio}
							disabled={!agent.audio}
						>
							Voice clip coming soon
						</button>
					</article>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
