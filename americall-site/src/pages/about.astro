---
import BaseLayout from '../layouts/BaseLayout.astro';
import { agents } from '../data/site';
---

<BaseLayout title="About Us" description="Meet the Americall team and learn how trained agents support appointment-setting and calling campaigns.">
	<section class="grid-surface bg-ameri-navy px-5 py-20 text-white lg:px-8">
		<div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1fr_360px]">
			<div class="reveal">
				<p class="text-sm font-black uppercase tracking-wide text-white/70">About Americall</p>
				<h1 class="mt-3 max-w-4xl text-4xl font-black leading-tight sm:text-5xl">
					A calling partner built on training, consistency, and follow-through.
				</h1>
				<p class="mt-5 max-w-3xl text-lg leading-8 text-white/75">
					Americall supports businesses that need reliable appointment-setting operations, trained agents, confirmation workflows, and campaign support that connects daily calling activity to sales outcomes.
				</p>
			</div>
			<img src="/images/americall-eagle.jpeg" alt="Americall eagle headset mark" class="reveal float-panel mx-auto max-h-80 rounded-md bg-white object-contain p-8 shadow-2xl shadow-black/25" />
		</div>
	</section>

	<section class="px-5 py-20 lg:px-8">
		<div class="mx-auto max-w-7xl">
			<div class="reveal max-w-3xl">
				<p class="text-sm font-black uppercase tracking-wide text-ameri-red">Agent voices</p>
				<h2 class="mt-3 text-3xl font-black text-ameri-navy sm:text-4xl">The human side of every campaign.</h2>
				<p class="mt-4 text-lg leading-8 text-ameri-muted">
					These are placeholder profiles for now. Replace them with real agent photos, names, quotes, and short voice clips before launch.
				</p>
			</div>
			<div class="mt-12 grid gap-6 md:grid-cols-3">
				{agents.map((agent) => (
					<article class="reveal lift-card group rounded-md border border-ameri-border bg-white p-6 hover:border-ameri-red/35">
						<div class="grid aspect-square place-items-center rounded-md bg-ameri-soft text-4xl font-black text-ameri-navy transition group-hover:bg-ameri-navy group-hover:text-white">
							{agent.initials}
						</div>
						<h3 class="mt-6 text-xl font-black text-ameri-navy">{agent.name}</h3>
						<p class="mt-1 text-sm font-bold uppercase tracking-wide text-ameri-red">{agent.role}</p>
						<p class="mt-4 leading-7 text-ameri-muted">"{agent.quote}"</p>
						<button
							type="button"
							class="mt-6 w-full rounded-md border border-ameri-border px-4 py-3 text-sm font-black text-ameri-navy transition hover:border-ameri-red hover:text-ameri-red disabled:cursor-not-allowed disabled:opacity-60"
							data-audio={agent.audio}
							disabled={!agent.audio}
						>
							Voice clip coming soon
						</button>
					</article>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
